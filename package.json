{
  "name": "petri-ts",
  "version": "0.1.6",
  "type": "module",
  "description": "A lightweight TypeScript Petri net engine",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "lint": "oxlint",
    "fmt": "oxfmt --write src test",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "petri-net",
    "state-machine",
    "workflow",
    "typescript",
    "reachability"
  ],
  "homepage": "https://www.joshtuddenham.dev/blog/petri-nets/",
  "license": "MIT",
  "devDependencies": {
    "oxfmt": "latest",
    "oxlint": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4"
  }
}
